rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isPartner() {
      return isLoggedIn() && 
        exists(/databases/$(database)/documents/partners/$(request.auth.uid));
    }

    function isAdmin() {
      return isLoggedIn() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── ADMINS ─────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ─── USERS ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isLoggedIn() && (isOwner(userId) || isPartner() || isAdmin());
      allow write: if isLoggedIn() && (isOwner(userId) || isPartner() || isAdmin());
    }

    // ─── WASTE REQUESTS ─────────────────────────────────────────
    match /wasteRequests/{requestId} {
      allow create: if isLoggedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      resource.data.partnerId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow update: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      resource.data.partnerId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ─── REQUESTS ───────────────────────────────────────────────
    match /requests/{requestId} {
      allow create: if isLoggedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow read:   if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      resource.data.partnerId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow update: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      resource.data.partnerId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ─── PARTNERS ───────────────────────────────────────────────
    match /partners/{partnerId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
                      partnerId == request.auth.uid ||
                      resource.data.id == request.auth.uid ||
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ─── PICKUP HISTORY ─────────────────────────────────────────
    match /pickupHistory/{docId} {
      allow read:   if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      resource.data.partnerId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
                      resource.data.partnerId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ─── SCHEDULED PICKUPS ──────────────────────────────────────
    match /scheduledPickups/{docId} {
      allow read:   if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      resource.data.partnerId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow create: if isLoggedIn()
                   
      allow update: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      resource.data.partnerId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ─── NOTIFICATIONS ──────────────────────────────────────────
    match /notifications/{docId} {
      allow read:   if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow delete: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
    }

    // ─── COMMUNITY POSTS ────────────────────────────────────────
    match /communityPosts/{postId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isAdmin()
                    );
      allow delete: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isAdmin()
                    );
    }

    // ─── WASTE LISTINGS ─────────────────────────────────────────
    match /wasteListings/{listingId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isAdmin()
                    );
      allow delete: if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isAdmin()
                    );
    }

    // ─── REWARD RULES ───────────────────────────────────────────
    match /rewardRules/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ─── REWARD TRANSACTIONS ────────────────────────────────────
    match /rewardTransactions/{docId} {
      allow read:   if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isPartner() ||
                      isAdmin()
                    );
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // ─── VOUCHERS ───────────────────────────────────────────────
    match /vouchers/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ─── REPORTS ────────────────────────────────────────────────
    match /reports/{docId} {
      allow read:   if isLoggedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isAdmin()
                    );
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // ─── AUDIT LOGS ─────────────────────────────────────────────
    match /auditLogs/{docId} {
      allow read:   if isAdmin();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

  }
}
